MONGO_URI=your_mongodb_connection_string
PORT=5000
# Public base URL used in generated short links + QR codes.
# Example: https://abcd-1234.ngrok-free.app or https://short.yourdomain.com
SHORTENER_BASE_URL=https://your-public-domain.com
# Frontend URL allowed to call backend API (CORS)
FRONTEND_URL=https://your-frontend-domain.com
# Optional: comma-separated list of extra allowed origins
# ALLOWED_ORIGINS=https://your-frontend-domain.com,https://another-domain.com
